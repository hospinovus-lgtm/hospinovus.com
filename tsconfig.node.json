{
  "compilerOptions": {
    "composite": true,

    "target": "ES2022",
    "lib": ["ES2022"],

    "module": "ESNext",
    "moduleResolution": "Node",

    "types": ["node"],

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "skipLibCheck": true,
    "noEmit": true
  },
  "include": [
    "vite.config.ts",
    "api"
  ]
}